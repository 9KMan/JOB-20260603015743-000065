# Environment variables
# Copy to .env and configure for your environment

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/support_bot

# Security
SECRET_KEY=change-me-to-something-secure-in-production

# OpenAI
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_EMBEDDING_MODEL=text-embedding-ada-002
OPENAI_MODEL=gpt-4o

# Optional: Anthropic
ANTHROPIC_API_KEY=

# Vector store (pgvector is default, set others if needed)
USE_PGVECTOR=true
PINECONE_API_KEY=
PINECONE_INDEX_NAME=support-bot-index
WEAVIATE_URL=
WEAVIATE_API_KEY=

# Debug mode
DEBUG=false